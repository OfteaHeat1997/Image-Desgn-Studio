# UniStudio — Environment variables
# Copy to .env.local for local dev:  cp .env.example .env.local
# In Coolify, set these in the app's "Environment Variables" tab (no file needed).

# ---- Database (PostgreSQL) ----
# Local Docker compose default. In Coolify, point to the managed Postgres service.
DATABASE_URL="postgresql://unistudio:unistudio@localhost:5432/unistudio"

# ---- Required AI providers ----
REPLICATE_API_TOKEN=""        # Image processing (Replicate)
FAL_KEY=""                    # Video generation (fal.ai). Some code also reads FAL_API_KEY.

# ---- Optional AI providers ----
ANTHROPIC_API_KEY=""          # AI agent planning (Claude). Without it the agent planner is disabled.
FASHN_API_KEY=""              # Premium virtual try-on
HEDRA_API_KEY=""              # Premium avatar generation
GOOGLE_TTS_API_KEY=""         # Google Cloud Text-to-Speech
WITHOUTBG_URL=""              # Self-hosted background-removal Docker service URL
FACE_SWAP_MODEL=""            # Override the default face-swap model id (optional)
LINGERIE_FLATTEN=""           # Lingerie pipeline flatten toggle (optional)

# ---- App URL ----
# Public URL of the deployment. On Coolify use your real domain, e.g. https://studio.tudominio.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"
